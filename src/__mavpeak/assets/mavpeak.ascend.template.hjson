{
    executable: {{{ROOT_DIR}}}/bin/mavpeak
    args: [
        {{#configuration.STARTUP_ARGS}}
        {{.}}
        {{/configuration.STARTUP_ARGS}}
    ]
    environment: {
        HOME: {{{ROOT_DIR}}}
        MAVPEAK_CONFIG_FILE: {{{ROOT_DIR}}}/config.hjson
        MAVBAKE_HOME: {{{model.MAVBAKE_HOME}}}
    }
    working_directory: {{{ROOT_DIR}}}/data
    restart: always
    restart_delay: 20
    user: {{{model.USER}}}
}